<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Sign Up</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    body {
      background: linear-gradient(to right, #0f172a, #1e293b);
    }
  </style>
</head>

<body class="min-h-screen flex items-center justify-center text-white">

  <div class="w-full max-w-md bg-white/10 backdrop-blur-lg rounded-2xl shadow-2xl p-8">

    <!-- Title -->
    <h2 class="text-3xl font-bold text-center mb-6">📝 Create Account</h2>

    <!-- ERROR MESSAGE (optional) -->
    <% if (error) { %>
      <div class="mb-4 p-3 bg-red-500/20 border border-red-400 rounded text-red-200 text-sm text-center">
        <%= error %>
      </div>
    <% } %>


    <!-- FORM -->
    <form action="/user" method="POST" class="space-y-4">

      <!-- NAME -->
      <div>
        <label class="block mb-1 text-sm text-gray-200">Full Name</label>
        <input
          type="text"
          name="name"
          required
          placeholder="John Doe"
          class="w-full px-4 py-2 rounded-lg bg-white/90 text-gray-900
                 focus:outline-none focus:ring-2 focus:ring-indigo-500"
        />
      </div>

      <!-- EMAIL -->
      <div>
        <label class="block mb-1 text-sm text-gray-200">Email</label>
        <input
          type="email"
          name="email"
          required
          placeholder="john@example.com"
          class="w-full px-4 py-2 rounded-lg bg-white/90 text-gray-900
                 focus:outline-none focus:ring-2 focus:ring-indigo-500"
        />
      </div>

      <!-- PASSWORD -->
      <div>
        <label class="block mb-1 text-sm text-gray-200">Password</label>
        <input
          type="password"
          name="password"
          required
          placeholder="••••••••"
          class="w-full px-4 py-2 rounded-lg bg-white/90 text-gray-900
                 focus:outline-none focus:ring-2 focus:ring-indigo-500"
        />
      </div>

      <!-- BUTTON -->
      <button
        type="submit"
        class="w-full py-3 mt-2 rounded-lg bg-indigo-600 hover:bg-indigo-700
               transition duration-200 font-semibold shadow-lg"
      >
        Sign Up
      </button>
    </form>

    <!-- LOGIN LINK -->
    <p class="text-sm text-gray-300 text-center mt-4">
      Already have an account?
      <a href="/login" class="text-indigo-400 hover:underline">Login</a>
    </p>

  </div>

</body>
</html>